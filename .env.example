# Google Sheets API (used in api/ server-side)
GOOGLE_SHEET_ID=17A-I1oIBfbG9c4oAiUqCr11RhOWFCXvkZM_IyzgKgqc
GOOGLE_SERVICE_EMAIL=
GOOGLE_PRIVATE_KEY=

# Firebase Auth (get from Firebase Console → Project Settings → General → Web apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# EmailJS (for email verification codes — free at emailjs.com)
# Create an account → Email Services → Add Service → get Service ID
# Email Templates → Create Template → use {{verification_code}} and {{to_email}}
# Account → API Keys → Public Key
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Firebase Console: enable these Authentication → Sign-in method providers:
#   - Google (for OAuth sign-in)
#   - Anonymous (for name-only sign-in)
#   - Phone (for SMS-based sign-in)
#
# Phone verification: requires Phone provider + reCAPTCHA (has SMS costs)
