{
  "name": "wedding-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env scripts/dev-server.mjs & vite",
    "dev:api": "node --env-file=.env scripts/dev-server.mjs",
    "build": "node scripts/verify-build.mjs",
    "deploy": "node scripts/verify-build.mjs && vercel --prod",
    "e2e": "node scripts/deploy-e2e.mjs",
    "e2e:local": "node scripts/deploy-e2e.mjs http://localhost:3000",
    "e2e:prod": "node scripts/deploy-e2e.mjs https://abhayandrebecca.com",
    "preview": "vite preview",
    "preview:check": "node scripts/preview-check.mjs",
    "sync": "node --env-file=.env scripts/sync-guests.mjs",
    "test": "vitest run",
    "test:full": "vitest run && npm run build",
    "test:local": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "firebase": "^12.14.0",
    "framer-motion": "^12.40.0",
    "googleapis": "^173.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.17.0",
    "resend": "^6.12.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "nodemailer": "^8.0.11",
    "playwright": "^1.60.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
